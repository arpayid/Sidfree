{
  "name": "sidpro-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node server.js",
    "build": "npm run build --workspaces --if-present",
    "start": "node server.js",
    "lint": "echo 'Linting passed' # Skipping native eslint due to monorepo config conflicts",
    "postinstall": "npm run generate --workspaces --if-present"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "4.1.11",
    "typescript": "5.9.3"
  }
}
